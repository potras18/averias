DATABASE_URL=postgresql://postgres:postgres@localhost:5433/averias
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/averias_test
# REQUIRED: generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_run_openssl_rand_-base64_48
PORT=3000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@example.com
# Comma-separated allowed origins for CORS (leave empty to disallow cross-origin requests)
# Example: https://app.tudominio.com,https://admin.tudominio.com
CORS_ORIGINS=
